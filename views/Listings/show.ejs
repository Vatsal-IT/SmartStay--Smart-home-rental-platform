<% layout("layouts/boilerPlate.ejs") %>

    <body>
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10 col-sm-12">

                    <!-- LISTING DETAILS -->
                    <div class="card shadow-sm overflow-hidden mb-4">
                        <img src="<%= listing.image.url %>" alt="listing image" class="card-img-top"
                            style="height: 320px; object-fit: cover;" />

                        <div class="card-body">
                            <h3 class="card-title mb-1">
                                <%= listing.title %>
                            </h3>

                            <p class="text-muted mb-1">
                                Owned by
                                <span class="fw-semibold text-dark">
                                    <%= listing.owner ? listing.owner.username : "Unknown" %>
                                </span>
                            </p>

                            <p class="text-muted mb-1">
                                <i class="fa-solid fa-tag"></i> <b>Category:</b>
                                <%= listing.category || "Not Specified" %>
                            </p>

                            <p class="text-muted mb-3 d-flex align-items-center flex-wrap gap-2">
                                <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
                                <a href="/chat?city=<%= encodeURIComponent(listing.location) %>" class="badge rounded-pill bg-info text-dark text-decoration-none px-3 py-2 ms-2">
                                    <i class="fa-regular fa-comments"></i> Join <%= listing.location %> Chat
                                </a>
                            </p>

                            <h5 class="mb-3">
                                ₹<%= listing.price.toLocaleString("en-IN") %>
                                    <span class="text-muted fs-6">/ night</span>
                            </h5>

                            <% if (currentUser && (!listing.owner || !currentUser._id.equals(listing.owner._id))) { %>
                            <!-- Booking Form -->
                            <div class="card mb-3">
                                <div class="card-body">
                                    <h5 class="card-title">Book this stay</h5>
                                    <form action="/listings/<%= listing._id %>/bookings" method="POST">
                                        <div class="mb-2">
                                            <label class="form-label">Check-in</label>
                                            <input type="date" name="booking[startDate]" class="form-control" required>
                                        </div>
                                        <div class="mb-2">
                                            <label class="form-label">Check-out</label>
                                            <input type="date" name="booking[endDate]" class="form-control" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Guests</label>
                                            <input type="number" name="booking[guests]" class="form-control" min="1" value="1">
                                        </div>
                                        <button class="btn btn-success w-100" type="submit">
                                            Book now
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <% } %>

                            <p class="card-text">
                                <%= listing.description %>
                            </p>

                            <hr>

                            <% if(currentUser && currentUser._id.equals(listing.owner._id)){%>
                                <div class="d-flex gap-2">
                                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-primary">
                                        Edit
                                    </a>

                                    <form action="/listings/<%= listing._id %>?_method=DELETE" method="post"
                                        onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                        <button class="btn btn-danger">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                                <%}%>

                        </div>
                    </div>

                    <!--  LEAVE A REVIEW -->
                    <div class="card shadow-sm p-4 mb-4">
                        <h4 class="mb-3">Leave a Review</h4>

                        <form action="/listings/<%= listing._id %>/reviews" method="post" class="needs-validation"
                            novalidate>
                            <!-- Rating -->
                            <div class="mb-3 mt-3">
                                <label class="form-label fw-semibold">
                                    Rating
                                </label>
                                <fieldset class="starability-slot">
                                    <legend>First rating:</legend>
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <!-- Comment -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Comment
                                </label>
                                <textarea class="form-control" rows="3" name="review[comment]" required></textarea>
                                <div class="invalid-feedback">
                                    Please enter a comment.
                                </div>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-primary">
                                    Submit Review
                                </button>
                            </div>
                        </form>
                    </div>

                    <!--  ALL REVIEWS -->
                    <% if(listing.reviews.length>0) { %>
                        <div class="card shadow-sm p-4 mb-5">
                            <h4 class="mb-3">All Reviews</h4>

                            <div class="row g-3">
                                <% for (let review of listing.reviews) { %>
                                    <div class="col-md-6 col-sm-12">
                                        <div class="card h-100 border">
                                            <div class="card-body d-flex flex-column">

                                                <!-- Author Name -->
                                                <h5 class="card-title">@<%= review.author ? review.author.username
                                                        : "Anonymous" %>
                                                </h5>

                                                <!-- Stars -->
                                                <div class="mb-2 text-warning">
                                                    <p class="starability-result" data-rating="3">
                                                        Rated: 3 stars
                                                    </p>
                                                </div>

                                                <!-- Comment -->
                                                <p class="card-text flex-grow-1">
                                                    <%= review.comment %>
                                                </p>

                                                <!-- Delete Button -->
                                                <% if(currentUser && review.author &&
                                                    currentUser._id.equals(review.author._id)) { %>
                                                    <form
                                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                        method="post"
                                                        onsubmit="return confirm('Are you sure you want to delete this review?');">
                                                        <button class="btn btn-sm btn-dark mt-2">
                                                            Delete
                                                        </button>
                                                    </form>
                                                    <% } %>

                                            </div>
                                        </div>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                        <%}%>

                           <div class="card shadow-sm p-4 mb-4">
                                <h3>Where you'll be</h3>
                                <div id="map" style="height: 400px;"></div>
                            </div>

                            <script>
                            const listing = <%- JSON.stringify(listing) %>;
                            </script>

                            <script src="/js/map.js"></script>

    </body>