<% layout("layouts/boilerPlate.ejs") %>

<body>
  <div class="container mt-5">
    <h2 class="mb-4">Booking Requests for My Listings</h2>

    <% if (bookings.length === 0) { %>
      <p>You have no booking requests yet.</p>
    <% } else { %>
      <div class="row g-4">
        <% bookings.forEach(booking => { %>
          <div class="col-lg-6 col-md-12">
            <div class="card h-100">
              <% if (booking.listing && booking.listing.image) { %>
                <img src="<%= booking.listing.image.url %>" class="card-img-top" alt="Listing image">
              <% } %>
              <div class="card-body">
                <h5 class="card-title">
                  <%= booking.listing ? booking.listing.title : "Listing removed" %>
                </h5>
                <p class="card-text mb-1">
                  <strong>Guest:</strong>
                  <%= booking.user ? booking.user.username : "User removed" %>
                </p>
                <p class="card-text mb-1">
                  <strong>Dates:</strong>
                  <%= booking.startDate.toDateString() %> - <%= booking.endDate.toDateString() %>
                </p>
                <p class="card-text mb-1">
                  <strong>Guests:</strong> <%= booking.guests %>
                </p>
                <p class="card-text mb-1">
                  <strong>Status:</strong>
                  <span class="badge
                    <%= booking.status === 'confirmed' ? 'bg-success' :
                        booking.status === 'accepted' ? 'bg-primary' :
                        booking.status === 'rejected' ? 'bg-danger' :
                        booking.status === 'expired' ? 'bg-secondary' :
                        'bg-warning text-dark' %>">
                    <%= booking.status %>
                  </span>
                </p>
                <p class="card-text mb-1">
                  <strong>Payment:</strong>
                  <span class="badge <%= booking.paymentStatus === 'paid' ? 'bg-success' : 'bg-warning text-dark' %>">
                    <%= booking.paymentStatus %>
                  </span>
                </p>
                <p class="card-text">
                  <strong>Total:</strong> ₹<%= booking.totalPrice.toLocaleString("en-IN") %>
                </p>

                <% if (booking.status === 'pending') { %>
                  <form action="/bookings/<%= booking._id %>/approve" method="POST" class="d-inline">
                    <button class="btn btn-success btn-sm" type="submit">Approve</button>
                  </form>
                  <form action="/bookings/<%= booking._id %>/reject" method="POST" class="d-inline ms-2">
                    <button class="btn btn-outline-danger btn-sm" type="submit">Reject</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>

